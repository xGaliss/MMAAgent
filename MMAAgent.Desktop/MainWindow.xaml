<Window x:Class="MMAAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MMAAgent.Desktop.ViewModels"
        xmlns:views="clr-namespace:MMAAgent.Desktop.Views"
        Title="MMA Agent"
        WindowStartupLocation="CenterScreen"
        Width="1200"
        Height="800"
        MinWidth="1000"
        MinHeight="700">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
            <views:MainMenuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:NewGameSetupViewModel}">
            <views:NewGameSetupView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:GameShellViewModel}">
            <views:GameShellView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RosterViewModel}">
            <views:RosterView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PromotionsViewModel}">
            <views:PromotionsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FightProfileViewModel}">
            <views:FightProfileView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MyFightersViewModel}">
            <views:MyFightersView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ScoutingViewModel}">
            <views:ScoutingView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:InboxViewModel}">
            <views:InboxView />
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentView}" />
    </Grid>
</Window>