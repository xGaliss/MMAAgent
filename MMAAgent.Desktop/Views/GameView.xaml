<UserControl x:Class="MMAAgent.Desktop.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding DateText}" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="   " />
                <TextBlock Text="{Binding WeekYearText}" VerticalAlignment="Center" />
                <TextBlock Text="   " />
                <TextBlock Text="{Binding SeedText}" VerticalAlignment="Center" Opacity="0.7" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Content="Advance Week"
                    Width="140"
                    Click="AdvanceWeek_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}" Background="#FFFDF4F4"/>
        </DockPanel>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Roster -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Roster.Fighters}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="W" Binding="{Binding Wins}" Width="60"/>
                    <DataGridTextColumn Header="L" Binding="{Binding Losses}" Width="60"/>
                    <DataGridTextColumn Header="País" Binding="{Binding CountryName}" Width="160"/>
                    <DataGridTextColumn Header="Peso" Binding="{Binding WeightClass}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- RIGHT: Events + Fights -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Events list -->
                <GroupBox Header="Últimos eventos" Margin="0,0,0,10">
                    <DataGrid ItemsSource="{Binding Events}"
                              SelectedItem="{Binding SelectedEvent}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding EventDate}" Width="110"/>
                            <DataGridTextColumn Header="Evento" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- Fights of selected event -->
                <GroupBox Grid.Row="1" Header="Resultados">
                    <DataGrid ItemsSource="{Binding SelectedEventFights}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Div" Binding="{Binding WeightClass}" Width="80"/>
                            <DataGridTextColumn Header="Combate" Binding="{Binding Matchup}" Width="*"/>
                            <DataGridTextColumn Header="Ganador" Binding="{Binding Winner}" Width="160"/>
                            <DataGridTextColumn Header="Método" Binding="{Binding Method}" Width="80"/>
                            <DataGridCheckBoxColumn Header="T" Binding="{Binding IsTitle}" Width="40"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>