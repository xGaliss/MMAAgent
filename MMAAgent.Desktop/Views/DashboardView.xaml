<UserControl x:Class="MMAAgent.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                BorderBrush="#666"
                BorderThickness="1"
                Background="#FFF8F8F8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Dashboard"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding DateText}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding WeekYearText}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SeedText}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Avanzar 1 semana"
                        Padding="14,8"
                        Margin="12,0,0,0"
                        Command="{Binding AdvanceWeekCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- Eventos -->
            <GroupBox Grid.Column="0" Header="Eventos recientes" Margin="0,0,10,0">
                <Grid>
                    <ListBox ItemsSource="{Binding Events}"
                             SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                             DisplayMemberPath="Name"/>
                </Grid>
            </GroupBox>

            <!-- Peleas del evento -->
            <GroupBox Grid.Column="1" Header="Cartelera del evento" Margin="0,0,10,0">
                <DataGrid ItemsSource="{Binding SelectedEventFights}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Peso" Binding="{Binding WeightClass}" Width="110"/>
                        <DataGridTextColumn Header="Combate" Binding="{Binding Matchup}" Width="*"/>
                        <DataGridTextColumn Header="Ganador" Binding="{Binding Winner}" Width="160"/>
                        <DataGridTextColumn Header="Método" Binding="{Binding Method}" Width="130"/>
                        <DataGridCheckBoxColumn Header="Título" Binding="{Binding IsTitle}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Destacados -->
            <GroupBox Grid.Column="2" Header="Destacados">
                <DataGrid ItemsSource="{Binding FeaturedFighters}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="140"/>
                        <DataGridTextColumn Header="Luchador" Binding="{Binding FighterName}" Width="*"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- World notes -->
        <GroupBox Grid.Row="2" Header="Notas del mundo" Margin="0,10,0,0">
            <ListBox ItemsSource="{Binding WorldNotes}"/>
        </GroupBox>
    </Grid>
</UserControl>