<UserControl x:Class="MMAAgent.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:MMAAgent.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:GameViewModel}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                BorderBrush="#666"
                BorderThickness="1"
                Background="#FFF8F8F8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding DateText}"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="   " />
                    <TextBlock Text="{Binding WeekYearText}"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="   " />
                    <TextBlock Text="{Binding SeedText}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Opacity="0.7"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="Advance Week"
                        Width="150"
                        Height="36"
                        Click="AdvanceWeek_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                        Background="#FFFDF4F4"/>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- WORLD STATUS -->
                <GroupBox Header="Estado actual" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="Fecha actual: " FontWeight="Bold"/>
                            <Run Text="{Binding DateText}"/>
                        </TextBlock>

                        <TextBlock Margin="0,0,0,6">
                            <Run Text="Semana / Año: " FontWeight="Bold"/>
                            <Run Text="{Binding WeekYearText}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Seed: " FontWeight="Bold"/>
                            <Run Text="{Binding SeedText}"/>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <!-- FEATURED FIGHTERS -->
                <GroupBox Grid.Row="1" Header="Peleadores destacados" Margin="0,0,0,10">
                    <DataGrid ItemsSource="{Binding FeaturedFighters}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="*"/>
                            <DataGridTextColumn Header="Peleador" Binding="{Binding FighterName}" Width="*"/>
                            <DataGridTextColumn Header="Dato" Binding="{Binding Value}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- QUICK NOTES / WORLD INFO -->
                <GroupBox Grid.Row="2" Header="Resumen del mundo">
                    <ListBox ItemsSource="{Binding WorldNotes}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </Grid>

            <!-- RIGHT COLUMN -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- EVENTS -->
                <GroupBox Header="Últimos eventos" Margin="0,0,0,10">
                    <DataGrid ItemsSource="{Binding Events}"
                              SelectedItem="{Binding SelectedEvent}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding EventDate}" Width="110"/>
                            <DataGridTextColumn Header="Evento" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- RESULTS -->
                <GroupBox Grid.Row="1" Header="Resultados del evento seleccionado">
                    <DataGrid ItemsSource="{Binding SelectedEventFights}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Div" Binding="{Binding WeightClass}" Width="80"/>
                            <DataGridTextColumn Header="Combate" Binding="{Binding Matchup}" Width="*"/>
                            <DataGridTextColumn Header="Ganador" Binding="{Binding Winner}" Width="160"/>
                            <DataGridTextColumn Header="Método" Binding="{Binding Method}" Width="80"/>
                            <DataGridCheckBoxColumn Header="T" Binding="{Binding IsTitle}" Width="40"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>