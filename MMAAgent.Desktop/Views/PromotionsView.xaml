<UserControl x:Class="MMAAgent.Desktop.Views.PromotionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lista -->
        <GroupBox Header="Promotions" Grid.Column="0">
            <DataGrid ItemsSource="{Binding Promotions}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Prestige" Binding="{Binding Prestige}" Width="80"/>
                    <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Detalle -->
        <GroupBox Header="Details" Grid.Column="2">
            <StackPanel Margin="10">
                <TextBlock Text="{Binding Selected.Name}" FontSize="18" FontWeight="Bold"/>
                <WrapPanel Margin="0,10,0,0">
                    <TextBlock Text="Prestige: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Selected.Prestige}"/>
                    <TextBlock Text="   Budget: " FontWeight="Bold" Margin="12,0,0,0"/>
                    <TextBlock Text="{Binding Selected.Budget}"/>
                </WrapPanel>

                <WrapPanel Margin="0,6,0,0">
                    <TextBlock Text="Interval (weeks): " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Selected.EventIntervalWeeks}"/>
                    <TextBlock Text="   Next event week: " FontWeight="Bold" Margin="12,0,0,0"/>
                    <TextBlock Text="{Binding Selected.NextEventWeek}"/>
                </WrapPanel>

                <TextBlock Margin="0,12,0,0" Opacity="0.7"
                           Text="(Siguiente: aquí meteremos WeightClasses + botones para activar/desactivar, cambiar interval, etc.)"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>