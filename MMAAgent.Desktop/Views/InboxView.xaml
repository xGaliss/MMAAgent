<UserControl x:Class="MMAAgent.Desktop.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.1*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                BorderBrush="#666"
                BorderThickness="1"
                Background="#FFF8F8F8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,6,0,0"
                               Opacity="0.8"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refrescar"
                        Margin="12,0,0,0"
                        Padding="12,8"
                        Command="{Binding RefreshCommand}"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="Generar oferta de prueba"
                        Margin="12,0,0,0"
                        Padding="12,8"
                        Command="{Binding GenerateTestOfferCommand}"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="3"
                        Content="Aceptar"
                        Margin="12,0,0,0"
                        Padding="12,8"
                        Command="{Binding AcceptSelectedOfferCommand}"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="4"
                        Content="Rechazar"
                        Margin="12,0,0,0"
                        Padding="12,8"
                        Command="{Binding RejectSelectedOfferCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <GroupBox Grid.Row="1" Header="Mensajes" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Messages}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding MessageType}" Width="130"/>
                    <DataGridTextColumn Header="Asunto" Binding="{Binding Subject}" Width="220"/>
                    <DataGridTextColumn Header="Mensaje" Binding="{Binding Body}" Width="*"/>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedDate}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Leído" Binding="{Binding IsRead}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Ofertas">
            <DataGrid ItemsSource="{Binding Offers}"
                      SelectedItem="{Binding SelectedOffer, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding OfferId}" Width="60"/>
                    <DataGridTextColumn Header="Tu luchador" Binding="{Binding FighterName}" Width="*"/>
                    <DataGridTextColumn Header="Rival" Binding="{Binding OpponentName}" Width="*"/>
                    <DataGridTextColumn Header="Bolsa" Binding="{Binding Purse}" Width="90"/>
                    <DataGridTextColumn Header="Bonus" Binding="{Binding WinBonus}" Width="90"/>
                    <DataGridTextColumn Header="Semanas" Binding="{Binding WeeksUntilFight}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Título" Binding="{Binding IsTitleFight}" Width="70"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>