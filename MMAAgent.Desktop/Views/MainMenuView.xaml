<UserControl x:Class="MMAAgent.Desktop.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="MMA Agent" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>
            <Button Content="New Game" Height="40" Margin="0,0,0,10" Click="NewGame_Click"/>
            <Button Content="Load Last Game" Height="40" Click="LoadLast_Click" IsEnabled="{Binding HasLastSave}"/>
        </StackPanel>
    </Grid>
</UserControl>