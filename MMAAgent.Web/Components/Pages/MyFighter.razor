@page "/myfighters"
@rendermode InteractiveServer
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services
@inject WebMyFightersService MyFightersService
@inject WebFighterActionService FighterActionService


<PageTitle>My Fighters - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>My Fighters</h1>
        <p class="muted-text">Your managed roster with fast access to profiles and contracts.</p>
    </div>
</div>

<section class="panel-card">
    <div class="roster-filters">
        <div>
            <label class="field-label">Search</label>
            <input class="text-input" @bind="_search" @bind:event="oninput" placeholder="Name..." />
        </div>
        <div>
            <label class="field-label">Promotion</label>
            <select class="text-input" @bind="_promotion">
                <option value="">All</option>
                @foreach (var item in _promotions)
                {
                    <option value="@item">@item</option>
                   
                }
                
            </select>
        </div>
        
        <div>
            <label class="field-label">Weight Class</label>
            <select class="text-input" @bind="_weightClass">
                <option value="">All</option>
                @foreach (var item in _weightClasses)
                {
                    <option value="@item">@item</option>
                }
            </select>
        </div>
        <div class="filter-actions">
            <button class="btn-primary" @onclick="LoadAsync">Apply</button>
            <button class="btn-secondary" @onclick="ResetAsync">Reset</button>
        </div>
    </div>
</section>

@if (_statusMessage is not null)
{
    <div class="panel-card" style="margin-top:20px;">@_statusMessage</div>
}

@if (_error is not null)
{
    <div class="panel-card error-panel" style="margin-top:20px;">@_error</div>
}
else if (_loading)
{
    <div class="panel-card" style="margin-top:20px;">Loading managed fighters...</div>
}
else
{
    <div class="myfighters-grid">
        @foreach (var item in _fighters)
        {
            <article class="panel-card managed-fighter-card">
                <div class="managed-top">
                    <div>
                        <div class="managed-name"><a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.Name</a></div>
                        <div class="muted-text">@item.WeightClass · @item.PromotionName</div>
                    </div>
                    @if (item.IsChampion)
                    {
                        <span class="champion-pill">Champion</span>
                    }
                </div>

                <div class="managed-stats">
                    <div><span>Record</span><strong>@item.Wins-@item.Losses-@item.Draws</strong></div>
                    <div><span>Rank</span><strong>@(item.RankPosition?.ToString() ?? "-")</strong></div>
                    <div><span>Contract</span><strong>@item.ContractStatus</strong></div>
                    <div><span>Salary</span><strong>@item.Salary</strong></div>
                </div>
                <div class="button-row" style="margin-top:14px;">
                    <a class="btn-secondary" href="@($"/fighters/{item.FighterId}")">View profile</a>
                    @if (item.PromotionId is null)
                    {
                        <select class="text-input" style="max-width:220px;" value="@GetSelectedPromotion(item.FighterId)" @onchange="e => OnPromotionChanged(item.FighterId, e.Value?.ToString())">
                            @foreach (var option in _promotionTargets)
                            {
                                <option value="@option.PromotionId">@option.PromotionName</option>
                            }
                        </select>
                        <button class="btn-secondary" @onclick="() => PitchAsync(item.FighterId)">Pitch promotion</button>
                    }
                    else if (item.ContractFightsRemaining > 0)
                    {
                        <button class="btn-secondary" @onclick="() => SeekFightAsync(item.FighterId)">Seek fight</button>
                    }

                    <button class="btn-secondary" @onclick="() => ReleaseAsync(item.FighterId)">Release</button>
                    <a class="btn-secondary" href="/inbox">Open inbox</a>
                </div>
                <div class="muted-text" style="margin-top:10px;">
                    Fights remaining: @item.ContractFightsRemaining / @item.TotalFightsInContract
                </div>
                <div class="muted-text" style="margin-top:6px;">
                    You can actively pitch free agents to promotions or ask signed fighters to seek a matchup. Results still flow through the inbox and live world systems.
                </div>
            </article>
        }
    </div>
}

@code {
    private string _search = "";
    private string _promotion = "";
    private string _weightClass = "";
    private List<string> _promotions = new();
    private List<string> _weightClasses = new();
    private List<ManagedFighterVm> _fighters = new();
    private List<PromotionOptionVm> _promotionTargets = new();
    private readonly Dictionary<int, int> _selectedPromotionByFighter = new();
    private bool _loading = true;
    private string? _error;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        var filters = await MyFightersService.LoadFiltersAsync();
        _promotions = filters.Promotions.ToList();
        _weightClasses = filters.WeightClasses.ToList();
        _promotionTargets = (await MyFightersService.LoadPromotionTargetsAsync()).ToList();
        await LoadAsync();
    }

    private async Task ResetAsync()
    {
        _search = "";
        _promotion = "";
        _weightClass = "";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            _fighters = (await MyFightersService.LoadAsync(_search, _promotion, _weightClass)).ToList();
            SeedPromotionSelections();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReleaseAsync(int fighterId)
    {
        await FighterActionService.ReleaseFighterAsync(fighterId);
        _statusMessage = "Fighter released from your management roster.";
        await LoadAsync();
    }

    private async Task PitchAsync(int fighterId)
    {
        var promotionId = GetSelectedPromotion(fighterId);
        if (promotionId <= 0)
        {
            _error = "Select a promotion first.";
            return;
        }

        var result = await FighterActionService.PitchToPromotionAsync(fighterId, promotionId);
        if (result.Success)
        {
            _statusMessage = result.Message;
            _error = null;
        }
        else
        {
            _error = result.Message;
            _statusMessage = null;
        }

        await LoadAsync();
    }

    private async Task SeekFightAsync(int fighterId)
    {
        var result = await FighterActionService.SeekFightAsync(fighterId);
        if (result.Success)
        {
            _statusMessage = result.Message;
            _error = null;
        }
        else
        {
            _error = result.Message;
            _statusMessage = null;
        }

        await LoadAsync();
    }

    private void SeedPromotionSelections()
    {
        if (_promotionTargets.Count == 0)
            return;

        var defaultPromotionId = _promotionTargets[0].PromotionId;
        foreach (var fighter in _fighters)
        {
            if (!_selectedPromotionByFighter.ContainsKey(fighter.FighterId))
                _selectedPromotionByFighter[fighter.FighterId] = defaultPromotionId;
        }
    }

    private int GetSelectedPromotion(int fighterId)
    {
        if (_selectedPromotionByFighter.TryGetValue(fighterId, out var promotionId))
            return promotionId;

        return _promotionTargets.Count > 0 ? _promotionTargets[0].PromotionId : 0;
    }

    private void OnPromotionChanged(int fighterId, string? rawValue)
    {
        if (int.TryParse(rawValue, out var promotionId))
            _selectedPromotionByFighter[fighterId] = promotionId;
    }

}
