@page "/roster"
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Fighters
@inject IFighterRepository FighterRepository

<PageTitle>Roster - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Roster</h1>
        <p class="muted-text">Current fighters loaded from your save.</p>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_fighters is null)
{
    <div class="panel-card">Cargando roster...</div>
}
else
{
    <div class="panel-card">
        <div class="table-toolbar">
            <div class="toolbar-title">@_fighters.Count fighters</div>
            <div class="toolbar-subtitle">Click a fighter name to open the full profile</div>
        </div>

        <table class="fighters-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Weight Class</th>
                    <th>Record</th>
                    <th>Country</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fighter in _fighters)
                {
                    <tr>
                        <td>
                            <a class="fighter-link" href="@($"/fighters/{fighter.Id}")">@fighter.Name</a>
                        </td>
                        <td>@fighter.WeightClass</td>
                        <td>@fighter.Wins-@fighter.Losses</td>
                        <td>@fighter.CountryName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<FighterSummary>? _fighters;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _fighters = await FighterRepository.GetRosterAsync(200);
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
    }
}
