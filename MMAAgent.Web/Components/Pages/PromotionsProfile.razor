@page "/promotions/{promotionId:int}"
@rendermode InteractiveServer
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services
@inject WebPromotionProfileService PromotionProfileService
@inject MMAAgent.Infrastructure.Persistence.Sqlite.Repositories.IEventRepository EventRepository

<PageTitle>Promotion Profile - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Promotion Profile</h1>
        <p class="muted-text">Champions, rankings, upcoming and recent activity for the selected promotion.</p>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_loading)
{
    <div class="panel-card">Cargando promotion profile...</div>
}
else if (_profile is null)
{
    <div class="panel-card">Promotion not found.</div>
}
else
{
    <div class="fight-profile-layout">
        <section class="panel-card profile-hero promotion-profile-hero @GetPromotionClass(_profile.Name)">
            <div class="promotion-hero-main">
                <div class="promotion-hero-left">
                    <div class="profile-header">
                        <div>
                            <div class="profile-name-row">
                                <h2 class="profile-name">@_profile.Name</h2>
                            </div>

                            <div class="muted-text">
                                Prestige @_profile.Prestige · Budget @_profile.Budget · Active: @(_profile.IsActive ? "Yes" : "No")
                            </div>
                        </div>

                        <div class="profile-record">@_profile.EventIntervalWeeks wk</div>
                    </div>

                    <div class="promotion-hero-stats">
                        <article class="promotion-stat-card">
                            <div class="promotion-stat-label">Next Event Week</div>
                            <div class="promotion-stat-value">@_profile.NextEventWeek</div>
                        </article>

                        <article class="promotion-stat-card">
                            <div class="promotion-stat-label">Champions</div>
                            <div class="promotion-stat-value">@_profile.Champions.Count</div>
                        </article>

                        <article class="promotion-stat-card">
                            <div class="promotion-stat-label">Ranked Fighters</div>
                            <div class="promotion-stat-value">@_profile.Rankings.Count</div>
                        </article>

                        <article class="promotion-stat-card">
                            <div class="promotion-stat-label">Status</div>
                            <div class="promotion-stat-value">@(_profile.IsActive ? "Active" : "Inactive")</div>
                        </article>
                    </div>
                </div>

                <div class="promotion-hero-right">
                    <img class="promotion-profile-logo-large"
                         src="@PromotionAssetsHelper.GetPromotionLogo(_profile.Name)"
                         alt="@_profile.Name" />
                </div>
            </div>
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Division Picture</div>

            @if (_profile.Divisions.Count == 0)
            {
                <div class="muted-text">No division picture has been built yet.</div>
            }
            else
            {
                <div class="dashboard-list">
                    @foreach (var division in _profile.Divisions)
                    {
                        <div class="dashboard-list-item">
                            <div class="toolbar-title">@division.WeightClass</div>
                            <div class="muted-text">
                                Champion:
                                @if (division.ChampionId is int championId && !string.IsNullOrWhiteSpace(division.ChampionName))
                                {
                                    <a class="fighter-link" href="@($"/fighters/{championId}")">@division.ChampionName</a>
                                }
                                else
                                {
                                    <span>@division.ChampionName</span>
                                }
                            </div>

                            @if (division.NextContenders.Count > 0)
                            {
                                <div class="muted-text" style="margin-top:8px;">
                                    Next up:
                                    @foreach (var contender in division.NextContenders)
                                    {
                                        <span style="margin-right:10px;">#@contender.QueueRank <a class="fighter-link" href="@($"/fighters/{contender.FighterId}")">@contender.FighterName</a></span>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(division.UpcomingStakes))
                            {
                                <div class="muted-text" style="margin-top:8px;">Stakes: @division.UpcomingStakes</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(division.RivalryHeadline))
                            {
                                <div class="muted-text" style="margin-top:8px;">Rivalry: @division.RivalryHeadline</div>
                            }
                        </div>
                    }
                </div>
            }
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Champions</div>

            <div class="promotion-champions-grid">
                @foreach (var item in _profile.Champions)
                {
                    <article class="belt-card">
                        <div class="belt-badge">@item.WeightClass[..Math.Min(2, item.WeightClass.Length)].ToUpper()</div>

                        <div class="belt-info">
                            <div class="belt-name">
                                <a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.FighterName</a>
                            </div>
                            <div class="belt-meta">@item.WeightClass Champion</div>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Top Rankings</div>

            @foreach (var group in _profile.Rankings.GroupBy(x => x.WeightClass))
            {
                <div class="ranking-block">
                    <div class="ranking-title">@group.Key</div>

                    <table class="fighters-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Fighter</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in group)
                            {
                                <tr>
                                    <td>@item.RankPosition</td>
                                    <td>
                                        <a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.FighterName</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Contender Queue</div>

            @if (_profile.Contenders.Count == 0)
            {
                <div class="muted-text">No contender queue has been built yet.</div>
            }
            else
            {
                @foreach (var group in _profile.Contenders.GroupBy(x => x.WeightClass))
                {
                    <div class="ranking-block">
                        <div class="ranking-title">@group.Key</div>

                        <table class="fighters-table">
                            <thead>
                                <tr>
                                    <th>Queue</th>
                                    <th>Fighter</th>
                                    <th>Score</th>
                                    <th>Read</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in group)
                                {
                                    <tr>
                                        <td>@item.QueueRank</td>
                                        <td>
                                            <a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.FighterName</a>
                                        </td>
                                        <td>@item.QueueScore</td>
                                        <td>@item.Notes</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Recent Events</div>

            <div class="dashboard-list">
                @if (_recentEvents.Count == 0)
                {
                    <div class="dashboard-list-item">No recent events.</div>
                }
                else
                {
                    @foreach (var item in _recentEvents)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public int promotionId { get; set; }

    private PromotionProfileVm? _profile;
    private bool _loading = true;
    private string? _error;
    private List<string> _recentEvents = new();

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _profile = await PromotionProfileService.LoadAsync(promotionId);

            var events = await EventRepository.GetLastEventsAsync(20);
            _recentEvents = events
                .Where(x => x.Name.Contains(_profile?.Name ?? "", StringComparison.OrdinalIgnoreCase))
                .Select(x => $"{x.EventDate} · {x.Name}")
                .Take(8)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetPromotionClass(string? name)
    {
        return name?.Trim().ToLowerInvariant() switch
        {
            "ufc" => "promotion-theme-ufc",
            "bellator" => "promotion-theme-bellator",
            "pfl" => "promotion-theme-pfl",
            "ksw" => "promotion-theme-ksw",
            "lux fight league" => "promotion-theme-lux",
            "regional latam" => "promotion-theme-regional",
            _ => "promotion-theme-default"
        };
    }
}
