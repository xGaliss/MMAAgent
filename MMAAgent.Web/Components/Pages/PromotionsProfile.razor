@page "/promotions/{promotionId:int}"
@rendermode InteractiveServer
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services
@inject WebPromotionProfileService PromotionProfileService

<PageTitle>Promotion Profile - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Promotion Profile</h1>
        <p class="muted-text">Champions and rankings for the selected promotion.</p>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_loading)
{
    <div class="panel-card">Cargando promotion profile...</div>
}
else if (_profile is null)
{
    <div class="panel-card">Promotion not found.</div>
}
else
{
    <div class="fight-profile-layout">
        <section class="panel-card profile-hero">
            <div class="profile-header">
                <div>
                    <div class="profile-name-row">
                        <h2 class="profile-name">@_profile.Name</h2>
                    </div>
                    <div class="muted-text">
                        Prestige @_profile.Prestige · Budget @_profile.Budget · Active: @(_profile.IsActive ? "Yes" : "No")
                    </div>
                </div>

                <div class="profile-record">
                    @_profile.EventIntervalWeeks wk
                </div>
            </div>

            <div class="profile-meta-grid">
                <div class="meta-box">
                    <div class="meta-label">Next Event Week</div>
                    <div class="meta-value">@_profile.NextEventWeek</div>
                </div>
                <div class="meta-box">
                    <div class="meta-label">Champions</div>
                    <div class="meta-value">@_profile.Champions.Count</div>
                </div>
                <div class="meta-box">
                    <div class="meta-label">Ranked Fighters</div>
                    <div class="meta-value">@_profile.Rankings.Count</div>
                </div>
                <div class="meta-box">
                    <div class="meta-label">Status</div>
                    <div class="meta-value">@(_profile.IsActive ? "Active" : "Inactive")</div>
                </div>
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Champions</div>
                <div class="toolbar-subtitle">Current title holders by division</div>
            </div>

            @if (_profile.Champions.Count == 0)
            {
                <div class="muted-text">No champions found.</div>
            }
            else
            {
                <div class="promotion-champions-grid">
                    @foreach (var item in _profile.Champions)
                    {
                        <article class="belt-card">
                            <div class="belt-badge">@item.WeightClass[..Math.Min(2, item.WeightClass.Length)].ToUpper()</div>
                            <div class="belt-info">
                                <div class="belt-name">
                                    <a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.FighterName</a>
                                </div>
                                <div class="belt-meta">@item.WeightClass Champion</div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Top Rankings</div>
                <div class="toolbar-subtitle">Top 10 by weight class</div>
            </div>

            @if (_profile.Rankings.Count == 0)
            {
                <div class="muted-text">No rankings found.</div>
            }
            else
            {
                @foreach (var group in _profile.Rankings.GroupBy(x => x.WeightClass))
                {
                    <div class="ranking-block">
                        <div class="ranking-title">@group.Key</div>
                        <table class="fighters-table">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Fighter</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in group)
                                {
                                    <tr>
                                        <td>@item.RankPosition</td>
                                        <td><a class="fighter-link" href="@($"/fighters/{item.FighterId}")">@item.FighterName</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </section>
    </div>
}

@code {
    [Parameter] public int promotionId { get; set; }

    private PromotionProfileVm? _profile;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            _profile = await PromotionProfileService.LoadAsync(promotionId);
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
        }
    }
}
