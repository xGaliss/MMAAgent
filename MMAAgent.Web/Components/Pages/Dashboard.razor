@page "/dashboard"
@rendermode InteractiveServer
@using MMAAgent.Application
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Common
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services
@inject IGameStateRepository GameStateRepository
@inject GameTimeService GameTimeService
@inject WebDashboardStatsService DashboardStatsService
@inject WebDashboardFeedService DashboardFeedService
@inject WebWeeklySummaryService WeeklySummaryService
@using MMAAgent.Application.Abstractions
@inject IWeeklyWorldUpdateService WeeklyWorldUpdateService


<PageTitle>Dashboard - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="muted-text">Live overview of your current MMA universe.</p>
    </div>

    <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <div class="date-card">
            <div class="date-card-label">Current Week</div>
            <div class="date-card-value">
                @(_gameState is null ? "-" : $"Week {_gameState.CurrentWeek} · {_gameState.CurrentDate}")
            </div>
        </div>

        <button type="button" class="btn-primary" @onclick="AdvanceWeekAsync" disabled="@_advancing">
            @(_advancing ? "Advancing..." : "Advance Week")
        </button>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_loading)
{
    <div class="panel-card">Cargando dashboard...</div>
}
else
{
    <div class="stats-grid">
        <article class="stat-card"><div class="stat-label">Current Date</div><div class="stat-value">@(_gameState?.CurrentDate ?? "-")</div></article>
        <article class="stat-card"><div class="stat-label">Week</div><div class="stat-value">@(_gameState?.CurrentWeek.ToString() ?? "-")</div></article>
        <article class="stat-card"><div class="stat-label">Fighters Loaded</div><div class="stat-value">@_fighterCount</div></article>
        <article class="stat-card"><div class="stat-label">Promotions Loaded</div><div class="stat-value">@_promotionCount</div></article>
    </div>

    <div class="dashboard-live-grid">
        <section class="panel-card">
            <div class="toolbar-title">Latest Events</div>
            <div class="dashboard-list">
                @foreach (var item in _latestEvents)
                {
                    <div class="dashboard-list-item">@item</div>
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Recent Inbox</div>
            <div class="dashboard-list">
                @foreach (var item in _recentMessages)
                {
                    <div class="dashboard-list-item">@item</div>
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Top Managed Fighters</div>
            <div class="dashboard-list">
                @foreach (var item in _topManaged)
                {
                    <div class="dashboard-list-item">@item</div>
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="toolbar-title">Managed Champions</div>
            <div class="dashboard-list">
                @if (_managedChampions.Count == 0)
                {
                    <div class="dashboard-list-item">None yet</div>
                }
                else
                {
                    @foreach (var item in _managedChampions)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>
    </div>

    <div class="panel-card" style="margin-top:20px;">
        <div class="toolbar-title">Pending Offers</div>
        <div class="stat-value">@_pendingOffers</div>
    </div>
}

@if (_summary is not null)
{
    <div class="panel-card" style="margin-top:20px;">
        <div class="toolbar-title">Last Week Summary</div>
        <div class="muted-text">Date: @_summary.CurrentDate · Week @_summary.CurrentWeek · Year @_summary.CurrentYear</div>
        <div class="muted-text">Simulated events: @_summary.SimulatedEvents</div>
        <div class="muted-text">New fight offers: @_summary.NewFightOffers</div>
        <div class="muted-text">New messages: @_summary.NewInboxMessages</div>
        <div class="muted-text">Ranking changes: @_summary.RankingChanges</div>
        <div class="muted-text">Headline: @(_summary.Headline ?? "-")</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="muted-text" style="margin-top: 14px;">@_status</div>
}

@code {
    private GameState? _gameState;
    private int _fighterCount;
    private int _promotionCount;
    private int _pendingOffers;
    private bool _loading = true;
    private bool _advancing;
    private string? _error;
    private string? _status;
    private WeeklyWorldUpdateSummary? _summary;
    private List<string> _latestEvents = new();
    private List<string> _recentMessages = new();
    private List<string> _topManaged = new();
    private List<string> _managedChampions = new();

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task AdvanceWeekAsync()
    {
        try
        {
            _advancing = true;
            _status = null;
            _error = null;

            var summary = await WeeklyWorldUpdateService.AdvanceWeekAsync();
            _summary = summary;

            await ReloadAsync();

            _status = $"Week advanced. New offers: {summary.NewFightOffers}. New messages: {summary.NewInboxMessages}.";
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _advancing = false;
        }
    }


    private async Task ReloadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _gameState = await GameStateRepository.GetAsync();
            var stats = await DashboardStatsService.LoadAsync();
            _fighterCount = stats.FighterCount;
            _promotionCount = stats.PromotionCount;

            var feed = await DashboardFeedService.LoadAsync();
            _latestEvents = feed.Events.ToList();
            _recentMessages = feed.Messages.ToList();
            _topManaged = feed.Managed.ToList();
            _managedChampions = feed.Champions.ToList();
            _pendingOffers = feed.PendingOffers;
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
