@page "/dashboard"
@rendermode InteractiveServer
@implements IDisposable
@using MMAAgent.Application
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Common
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services

@inject IGameStateRepository GameStateRepository
@inject GameTimeService GameTimeService
@inject WebDashboardStatsService DashboardStatsService
@inject WebDashboardFeedService DashboardFeedService
@inject WebWeeklySummaryService WeeklySummaryService
@inject InboxStatusService InboxStatusService

<PageTitle>Dashboard - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="muted-text">Live overview of your current MMA universe.</p>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_loading)
{
    <div class="panel-card">Loading dashboard...</div>
}
else
{
    <div class="stats-grid">
        <article class="stat-card">
            <div class="stat-label">Fighters Loaded</div>
            <div class="stat-value">@_fighterCount</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Promotions Loaded</div>
            <div class="stat-value">@_promotionCount</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Pending Fight Offers</div>
            <div class="stat-value">@_pendingFightOffers</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Pending Contract Offers</div>
            <div class="stat-value">@_pendingContractOffers</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Unread Messages</div>
            <div class="stat-value">@_unreadMessages</div>
        </article>
    </div>

    <div class="dashboard-live-grid">
        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">World Agenda</div>
                <div class="toolbar-subtitle">@_agenda.Count items</div>
            </div>

            <div class="dashboard-list">
                @if (_agenda.Count == 0)
                {
                    <div class="dashboard-list-item">No urgent milestones.</div>
                }
                else
                {
                    @foreach (var item in _agenda)
                    {
                        <div class="dashboard-agenda-item">
                            <div class="dashboard-agenda-top">
                                <span class="message-badge">@FormatAgendaType(item.EventType)</span>
                                <span class="message-date">@item.ScheduledDate</span>
                            </div>
                            <div class="dashboard-agenda-headline">@item.Headline</div>
                            @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                            {
                                <div class="muted-text">@item.Subtitle</div>
                            }
                        </div>
                    }
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Latest Events</div>
                <div class="toolbar-subtitle">@_latestEvents.Count items</div>
            </div>

            <div class="dashboard-list">
                @if (_latestEvents.Count == 0)
                {
                    <div class="dashboard-list-item">No recent events.</div>
                }
                else
                {
                    @foreach (var item in _latestEvents)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Recent Inbox</div>
                <div class="toolbar-subtitle">@_recentMessages.Count items</div>
            </div>

            <div class="dashboard-list">
                @if (_recentMessages.Count == 0)
                {
                    <div class="dashboard-list-item">No recent messages.</div>
                }
                else
                {
                    @foreach (var item in _recentMessages)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>

            <div style="margin-top:12px;">
                <a class="btn-secondary" href="/inbox">Go to Inbox</a>
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Top Managed Fighters</div>
                <div class="toolbar-subtitle">@_topManaged.Count items</div>
            </div>

            <div class="dashboard-list">
                @if (_topManaged.Count == 0)
                {
                    <div class="dashboard-list-item">No managed fighters yet.</div>
                }
                else
                {
                    @foreach (var item in _topManaged)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Managed Champions</div>
                <div class="toolbar-subtitle">@_managedChampions.Count items</div>
            </div>

            <div class="dashboard-list">
                @if (_managedChampions.Count == 0)
                {
                    <div class="dashboard-list-item">None yet.</div>
                }
                else
                {
                    @foreach (var item in _managedChampions)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>
    </div>

    <div class="dashboard-live-grid" style="margin-top:20px;">
        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Pending Fight Offers</div>
                <div class="toolbar-subtitle">@_pendingFightOffers</div>
            </div>

            <div class="dashboard-list">
                @if (_pendingFightOfferItems.Count == 0)
                {
                    <div class="dashboard-list-item">No pending fight offers.</div>
                }
                else
                {
                    @foreach (var item in _pendingFightOfferItems)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>

        <section class="panel-card">
            <div class="table-toolbar">
                <div class="toolbar-title">Pending Contract Offers</div>
                <div class="toolbar-subtitle">@_pendingContractOffers</div>
            </div>

            <div class="dashboard-list">
                @if (_pendingContractOfferItems.Count == 0)
                {
                    <div class="dashboard-list-item">No pending contract offers.</div>
                }
                else
                {
                    @foreach (var item in _pendingContractOfferItems)
                    {
                        <div class="dashboard-list-item">@item</div>
                    }
                }
            </div>
        </section>
    </div>
}

@if (_summary is not null)
{
    <div class="panel-card" style="margin-top:20px;">
        <div class="table-toolbar">
            <div class="toolbar-title">Last Week Summary</div>
            <div class="toolbar-subtitle">Week @_summary.NewWeek · @_summary.NewDate</div>
        </div>

        <div class="summary-grid">
            <div class="summary-row"><strong>Year:</strong> @_summary.NewYear</div>
            <div class="summary-row"><strong>Recent events loaded:</strong> @_summary.RecentEventsLoaded</div>
            <div class="summary-row"><strong>New inbox messages:</strong> @_summary.NewMessages</div>
            <div class="summary-row"><strong>Headline:</strong> @(_summary.Headline ?? "-")</div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="muted-text" style="margin-top:14px;">@_status</div>
}

@code {
    private GameState? _gameState;
    private int _fighterCount;
    private int _promotionCount;
    private int _pendingFightOffers;
    private int _pendingContractOffers;
    private int _unreadMessages;

    private bool _loading = true;
    private string? _error;
    private string? _status;

    private WeeklyAdvanceSummaryVm? _summary;

    private List<string> _latestEvents = new();
    private List<string> _recentMessages = new();
    private List<string> _topManaged = new();
    private List<string> _managedChampions = new();
    private List<string> _pendingFightOfferItems = new();
    private List<string> _pendingContractOfferItems = new();
    private List<AgendaItemVm> _agenda = new();

    protected override async Task OnInitializedAsync()
    {
        InboxStatusService.Changed += HandleInboxStatusChanged;
        await InboxStatusService.EnsureStartedAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _gameState = await GameStateRepository.GetAsync();

            var stats = await DashboardStatsService.LoadAsync();
            _fighterCount = stats.FighterCount;
            _promotionCount = stats.PromotionCount;
            _unreadMessages = stats.UnreadMessages;
            _pendingFightOffers = stats.PendingFightOffers;
            _pendingContractOffers = stats.PendingContractOffers;

            var feed = await DashboardFeedService.LoadAsync();
            _agenda = feed.Agenda.ToList();
            _latestEvents = feed.Events.ToList();
            _recentMessages = feed.Messages.ToList();
            _topManaged = feed.Managed.ToList();
            _managedChampions = feed.Champions.ToList();
            _pendingFightOfferItems = feed.PendingFightOfferItems?.ToList() ?? new();
            _pendingContractOfferItems = feed.PendingContractOfferItems?.ToList() ?? new();
            _summary = await WeeklySummaryService.BuildAsync();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleInboxStatusChanged()
    {
        if (_loading)
            return;

        _ = InvokeAsync(ReloadAsync);
    }

    public void Dispose()
    {
        InboxStatusService.Changed -= HandleInboxStatusChanged;
    }

    private static string FormatAgendaType(string eventType)
        => eventType switch
        {
            "Decision" => "Decision",
            "CampStart" => "Camp",
            "FightWeek" => "Fight Week",
            "WeighIn" => "Weigh-In",
            "FightNight" => "Fight Night",
            "Recovery" => "Recovery",
            _ => eventType
        };
}
