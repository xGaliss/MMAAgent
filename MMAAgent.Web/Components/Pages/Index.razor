@page "/"
@layout MMAAgent.Web.Components.Layout.MenuLayout
@rendermode InteractiveServer
@using MMAAgent.Web.Models
@using MMAAgent.Web.Services
@inject WebGameSessionService GameSession
@inject WebMainMenuService MainMenuService
@inject NavigationManager Navigation

<PageTitle>Main Menu - MMA Agent</PageTitle>

<div class="menu-screen">
    <section class="menu-hero-card">
        <div class="menu-kicker">MAIN MENU</div>
        <h1 class="menu-hero-title">Start your MMA management career</h1>
        <p class="menu-hero-text">
            Create a new world from the template database or load an existing save file.
        </p>
    </section>

    <div class="menu-card-grid">
        <section class="menu-card">
            <div class="menu-card-title">Detected Saves</div>
            <div class="menu-card-subtitle">Recent saves found on this machine.</div>

            <div class="save-card-list">
                @foreach (var save in _saves)
                {
                    <article class="save-card">
                        <div>
                            <div class="save-name">@save.FileName</div>
                            <div class="muted-text">@save.Path</div>
                            <div class="muted-text">@save.LastWriteTimeUtc.ToLocalTime()</div>
                        </div>
                        <div class="button-row">
                            <button class="btn-primary" @onclick="() => LoadDetectedAsync(save.Path)">Load</button>
                            <button class="btn-secondary" @onclick="() => StartRename(save.Path)">Rename</button>
                            <button class="btn-secondary" @onclick="() => DeleteSaveAsync(save.Path)">Delete</button>
                        </div>
                    </article>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_renamePath))
            {
                <div class="form-stack" style="margin-top:16px;">
                    <label class="field-label">Rename selected save</label>
                    <input class="text-input" @bind="_renameName" placeholder="New save name" />
                    <div class="button-row">
                        <button class="btn-primary" @onclick="RenameSaveAsync">Confirm rename</button>
                        <button class="btn-secondary" @onclick="CancelRename">Cancel</button>
                    </div>
                </div>
            }
        </section>

        <section class="menu-card">
            <div class="menu-card-title">New Game / Manual Load</div>
            <div class="menu-card-subtitle">Same flow as desktop: template DB, world generation, initial signing and rankings.</div>

            <div class="form-stack">
                <label class="field-label">Save path</label>
                <input class="text-input" @bind="_loadPath" placeholder="C:\Ruta\A\Tu\Save.db" />

                <div class="button-row">
                    <button class="btn-secondary" @onclick="LoadConfiguredAsync" disabled="@_busy">Load configured save</button>
                    <button class="btn-secondary" @onclick="LoadLastAsync" disabled="@_busy">Load last save</button>
                    <button class="btn-primary" @onclick="LoadByPathAsync" disabled="@_busy">Load by path</button>
                </div>

                <label class="field-label">Save name</label>
                <input class="text-input" @bind="_saveName" placeholder="MiPartida" />

                <label class="field-label">Agent name</label>
                <input class="text-input" @bind="_agentName" placeholder="Alejandro" />

                <label class="field-label">Agency name</label>
                <input class="text-input" @bind="_agencyName" placeholder="Galiss Management" />

                <label class="field-label">Fighter count</label>
                <input class="text-input" type="number" @bind="_fighterCount" />

                <div class="button-row">
                    <button class="btn-primary" @onclick="CreateNewGameAsync" disabled="@_busy">
                        @(_busy ? "Working..." : "Create new game")
                    </button>
                </div>

                <div class="muted-text">Active save: @(_currentSavePath ?? "none")</div>
            </div>
        </section>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="menu-feedback success">@_status</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="menu-feedback error">@_error</div>
    }
</div>

@code {
    private bool _busy;
    private string? _status;
    private string? _error;
    private string _loadPath = "";
    private string _saveName = "MiPartida";
    private string _agentName = "";
    private string _agencyName = "";
    private int _fighterCount = 800;
    private string? _currentSavePath;
    private List<SaveCardVm> _saves = new();
    private string? _renamePath;
    private string _renameName = "";

    protected override async Task OnInitializedAsync()
    {
        _currentSavePath = GameSession.CurrentSavePath;
        _saves = (await MainMenuService.DetectSavesAsync()).ToList();
    }

    private void StartRename(string path)
    {
        _renamePath = path;
        _renameName = Path.GetFileNameWithoutExtension(path);
    }

    private void CancelRename()
    {
        _renamePath = null;
        _renameName = "";
    }

    private async Task RenameSaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_renamePath)) return;
        await MainMenuService.RenameSaveAsync(_renamePath, _renameName);
        CancelRename();
        _saves = (await MainMenuService.DetectSavesAsync()).ToList();
    }

    private async Task DeleteSaveAsync(string path)
    {
        await MainMenuService.DeleteSaveAsync(path);
        _saves = (await MainMenuService.DetectSavesAsync()).ToList();
    }

    private async Task LoadDetectedAsync(string path)
    {
        await RunAsync(async () =>
        {
            await GameSession.LoadByPathAsync(path);
            _currentSavePath = GameSession.CurrentSavePath;
            Navigation.NavigateTo("/dashboard");
        });
    }

    private async Task LoadConfiguredAsync()
    {
        await RunAsync(async () =>
        {
            await GameSession.LoadConfiguredSaveAsync();
            _currentSavePath = GameSession.CurrentSavePath;
            Navigation.NavigateTo("/dashboard");
        });
    }

    private async Task LoadLastAsync()
    {
        await RunAsync(async () =>
        {
            var ok = await GameSession.TryLoadLastSaveAsync();
            if (!ok) throw new InvalidOperationException("No last save was found.");
            _currentSavePath = GameSession.CurrentSavePath;
            Navigation.NavigateTo("/dashboard");
        });
    }

    private async Task LoadByPathAsync()
    {
        await RunAsync(async () =>
        {
            await GameSession.LoadByPathAsync(_loadPath);
            _currentSavePath = GameSession.CurrentSavePath;
            Navigation.NavigateTo("/dashboard");
        });
    }

    private async Task CreateNewGameAsync()
    {
        await RunAsync(async () =>
        {
            var path = await GameSession.CreateNewGameAsync(_saveName, _agentName, _agencyName, _fighterCount);
            _currentSavePath = path;
            Navigation.NavigateTo("/dashboard");
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        try
        {
            _busy = true;
            _error = null;
            _status = null;
            await action();
            _saves = (await MainMenuService.DetectSavesAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _busy = false;
        }
    }
}
