@page "/"
@using MMAAgent.Application
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Common
@inject IGameStateRepository GameStateRepository
@inject IFighterRepository FighterRepository
@inject IPromotionRepository PromotionRepository
@inject GameTimeService GameTimeService

<PageTitle>Dashboard - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="muted-text">Live overview of your current MMA universe.</p>
    </div>

    <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <div class="date-card">
            <div class="date-card-label">Current Week</div>
            <div class="date-card-value">
                @(_gameState is null ? "-" : $"Week {_gameState.CurrentWeek} · {_gameState.CurrentDate}")
            </div>
        </div>

        <button type="button" class="btn-primary" @onclick="AdvanceWeekAsync" disabled="@_advancing">
            @(_advancing ? "Advancing..." : "Advance Week")
        </button>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_loading)
{
    <div class="panel-card">Cargando dashboard...</div>
}
else
{
    <div class="stats-grid">
        <article class="stat-card">
            <div class="stat-label">Current Date</div>
            <div class="stat-value">@(_gameState?.CurrentDate ?? "-")</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Week</div>
            <div class="stat-value">@(_gameState?.CurrentWeek.ToString() ?? "-")</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Fighters Loaded</div>
            <div class="stat-value">@_fighterCount</div>
        </article>

        <article class="stat-card">
            <div class="stat-label">Promotions Loaded</div>
            <div class="stat-value">@_promotionCount</div>
        </article>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="muted-text" style="margin-top: 14px;">@_status</div>
}

@code {
    private GameState? _gameState;
    private int _fighterCount;
    private int _promotionCount;
    private bool _loading = true;
    private bool _advancing;
    private string? _error;
    private string? _status;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task AdvanceWeekAsync()
    {
        try
        {
            _advancing = true;
            _status = null;
            _error = null;

            await GameTimeService.AdvanceWeeksAsync(1);
            await ReloadAsync();

            _status = "Semana avanzada correctamente.";
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _advancing = false;
        }
    }

    private async Task ReloadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _gameState = await GameStateRepository.GetAsync();
            _fighterCount = (await FighterRepository.GetRosterAsync(200)).Count;
            _promotionCount = (await PromotionRepository.GetAllAsync()).Count;
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}