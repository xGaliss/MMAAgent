@page "/promotions"
@using MMAAgent.Application.Abstractions
@using MMAAgent.Application.DTOs
@inject IPromotionRepository PromotionRepository
@inject NavigationManager Navigation

<PageTitle>Promotions - MMA Agent</PageTitle>

<div class="page-header">
    <div>
        <h1>Promotions</h1>
        <p class="muted-text">Promotion data loaded from your current save.</p>
    </div>
</div>

@if (_error is not null)
{
    <div class="panel-card error-panel">@_error</div>
}
else if (_promotions is null)
{
    <div class="panel-card">Cargando promotions...</div>
}
else
{
    <div class="promotion-grid">
        @foreach (var promotion in _promotions)
        {
            <article class="panel-card promotion-card"
                     @onclick="() => GoToPromotion(promotion.Id)">
                <div class="promotion-logo-wrap">
                    <img class="promotion-logo"
                         src="@PromotionAssetsHelper.GetPromotionLogo(promotion.Name)"
                         alt="@promotion.Name" />
                </div>

                <div class="promotion-content">
                    <div class="promotion-name">
                        @promotion.Name
                    </div>

                    <div class="promotion-meta">Prestige: @promotion.Prestige</div>
                    <div class="promotion-meta">Budget: @promotion.Budget</div>
                    <div class="promotion-meta">Active: @(promotion.IsActive ? "Yes" : "No")</div>
                    <div class="promotion-meta">Event Interval: @promotion.EventIntervalWeeks weeks</div>
                    <div class="promotion-meta">Next Event Week: @promotion.NextEventWeek</div>
                </div>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyList<PromotionListItem>? _promotions;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _promotions = await PromotionRepository.GetAllAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void GoToPromotion(int id)
    {
        Navigation.NavigateTo($"/promotions/{id}");
    }
}