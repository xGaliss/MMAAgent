@inherits LayoutComponentBase
@implements IDisposable
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Common
@using MMAAgent.Web.Services

@inject IGameStateRepository GameStateRepository
@inject InboxStatusService InboxStatusService
@inject HighlightNotificationService HighlightNotificationService
@inject NavigationManager Navigation
@inject WebTimeAdvanceService TimeAdvanceService

<style>
    .arena-ticker {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 14px;
        margin: 0 24px 10px;
        padding: 10px 14px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(90deg, rgba(10, 17, 31, 0.98), rgba(14, 23, 42, 0.96));
        box-shadow: 0 18px 40px rgba(0,0,0,0.24);
        overflow: hidden;
    }

    .arena-ticker-label {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(212,175,55,0.18), rgba(245,222,124,0.08));
        border: 1px solid rgba(212,175,55,0.22);
        color: #f5de7c;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .arena-ticker-viewport {
        position: relative;
        min-width: 0;
        overflow: hidden;
        mask-image: linear-gradient(90deg, transparent 0, black 6%, black 94%, transparent 100%);
        -webkit-mask-image: linear-gradient(90deg, transparent 0, black 6%, black 94%, transparent 100%);
    }

    .arena-ticker-track {
        display: inline-flex;
        align-items: center;
        gap: 20px;
        min-width: max-content;
        white-space: nowrap;
        animation: arenaTickerScroll 36s linear infinite;
        will-change: transform;
    }

    .arena-ticker-track-single {
        animation: none;
    }

    .arena-ticker:hover .arena-ticker-track {
        animation-play-state: paused;
    }

    .arena-ticker-item {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        color: #eaf0ff;
        flex-shrink: 0;
        text-decoration: none;
    }

    .arena-ticker-positive { border-color: rgba(34,197,94,0.24); }
    .arena-ticker-warn { border-color: rgba(245,158,11,0.24); }
    .arena-ticker-danger { border-color: rgba(248,113,113,0.26); }

    .arena-ticker-type {
        color: #f5de7c;
        font-size: 0.74rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .arena-ticker-text {
        color: #d7e0fb;
        font-size: 0.9rem;
    }

    .arena-ticker-action {
        min-height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04);
        color: #eef3ff;
        font-size: 0.82rem;
        font-weight: 800;
        cursor: pointer;
        white-space: nowrap;
    }

    @@keyframes arenaTickerScroll {
        from { transform: translateX(0); }
        to { transform: translateX(calc(-50% - 10px)); }
    }

    @@media (max-width: 780px) {
        .arena-ticker {
            grid-template-columns: 1fr;
            margin-left: 18px;
            margin-right: 18px;
        }

        .arena-ticker-action {
            justify-self: start;
        }
    }
</style>

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-glow"></div>

        <div class="brand-block">
            <div class="brand-logo-wrap">
                <div class="brand-logo">M</div>
            </div>

            <div class="brand-copy">
                <div class="brand-title">MMA Agent</div>
                <div class="brand-subtitle">Elite Fight Management</div>
            </div>
        </div>

        <div class="sidebar-section-title">Navigation</div>

        <nav class="sidebar-nav">
            <NavLink href="/dashboard" class="nav-item"><span class="nav-icon">🏠</span><span>Dashboard</span></NavLink>
            <NavLink href="/myfighters" class="nav-item"><span class="nav-icon">🧑‍🤝‍🧑</span><span>My Fighters</span></NavLink>
            <NavLink href="/roster" class="nav-item"><span class="nav-icon">🥊</span><span>Roster</span></NavLink>
            <NavLink href="/divisions" class="nav-item"><span class="nav-icon">📊</span><span>Divisions</span></NavLink>
            <NavLink href="/promotions" class="nav-item"><span class="nav-icon">🏆</span><span>Promotions</span></NavLink>
            <NavLink href="/events" class="nav-item"><span class="nav-icon">📅</span><span>Events</span></NavLink>
            <NavLink href="/inbox" class="nav-item nav-item-with-badge">
                <span class="nav-icon">📨</span>
                <div class="nav-copy">
                    <span>Inbox</span>
                    @if (InboxStatusService.HasAttention)
                    {
                        <span class="nav-item-badge" title="New inbox activity">@FormatAttentionCount(InboxStatusService.AttentionCount)</span>
                    }
                </div>
            </NavLink>
            <NavLink href="/agent" class="nav-item"><span class="nav-icon">🕴️</span><span>Agent</span></NavLink>
            <NavLink href="/" class="nav-item"><span class="nav-icon">🎮</span><span>Main Menu</span></NavLink>
        </nav>
    </aside>

    <div class="main-area">
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-kicker">CAREER MODE</div>

                <div class="topbar-title-row">
                    <h1 class="topbar-title">MMA Agent</h1>
                    <span class="live-pill">LIVE UNIVERSE</span>
                </div>

                <div class="topbar-subtitle">Elite fight business simulation</div>
            </div>

            <div class="topbar-right">
                <div class="date-card topbar-date-card">
                    <div class="date-card-label">Current Week</div>
                    <div class="date-card-value">
                        @(_gameState is null ? "-" : $"Week {_gameState.CurrentWeek} · {_gameState.CurrentDate}")
                    </div>
                </div>

                <button type="button"
                        class="btn-primary"
                        @onclick="AdvanceWeekAsync"
                        disabled="@(_advancing || _loadingState)">
                    @(_advancing ? "Advancing..." : "Advance Week")
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="@(() => AdvanceDaysAsync(1))"
                        disabled="@(_advancing || _loadingState)">
                    +1 Day
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="@(() => AdvanceDaysAsync(3))"
                        disabled="@(_advancing || _loadingState)">
                    +3 Days
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="@(() => AdvanceDaysAsync(15))"
                        disabled="@(_advancing || _loadingState)">
                    +15 Days
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="AdvanceToNextMilestoneAsync"
                        disabled="@(_advancing || _loadingState)">
                    Next Milestone
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="OpenInbox">
                    Open Inbox
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_layoutStatus))
        {
            <div class="layout-status muted-text">@_layoutStatus</div>
        }

        @if (HighlightNotificationService.Items.Count > 0)
        {
            <section class="arena-ticker">
                <div class="arena-ticker-label">Live Wire</div>
                <div class="arena-ticker-viewport">
                    <div class="arena-ticker-track @(HighlightNotificationService.Items.Count <= 1 ? "arena-ticker-track-single" : string.Empty)">
                        @foreach (var item in HighlightNotificationService.Items)
                        {
                            <a class="arena-ticker-item arena-ticker-@item.Tone"
                               href="/inbox"
                               title="@item.Body">
                                <span class="arena-ticker-type">@FormatHighlightType(item.MessageType)</span>
                                <span class="arena-ticker-text">@BuildTickerText(item)</span>
                            </a>
                        }

                        @if (HighlightNotificationService.Items.Count > 1)
                        {
                            @foreach (var item in HighlightNotificationService.Items)
                            {
                                <a class="arena-ticker-item arena-ticker-@item.Tone"
                                   href="/inbox"
                                   aria-hidden="true"
                                   tabindex="-1">
                                    <span class="arena-ticker-type">@FormatHighlightType(item.MessageType)</span>
                                    <span class="arena-ticker-text">@BuildTickerText(item)</span>
                                </a>
                            }
                        }
                    </div>
                </div>

                <button type="button"
                        class="arena-ticker-action"
                        @onclick="DismissAllHighlightsAsync"
                        disabled="@_advancing">
                    Clear
                </button>
            </section>
        }

        <main class="page-content">
            @Body
        </main>
    </div>
</div>

@code {
    private GameState? _gameState;
    private bool _loadingState = true;
    private bool _advancing;
    private string? _layoutStatus;

    protected override async Task OnInitializedAsync()
    {
        InboxStatusService.Changed += HandleInboxStatusChanged;
        HighlightNotificationService.Changed += HandleHighlightChanged;
        await InboxStatusService.EnsureStartedAsync();
        await HighlightNotificationService.EnsureStartedAsync();
        await LoadGameStateAsync();
    }

    private async Task LoadGameStateAsync()
    {
        try
        {
            _loadingState = true;
            _gameState = await GameStateRepository.GetAsync();
        }
        finally
        {
            _loadingState = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AdvanceWeekAsync()
    {
        if (_advancing)
            return;

        try
        {
            _advancing = true;
            _layoutStatus = null;

            var result = await TimeAdvanceService.AdvanceDaysAsync(7);
            await LoadGameStateAsync();
            await InboxStatusService.RefreshAsync();
            await HighlightNotificationService.RefreshAsync();

            _layoutStatus = result.Message;

            Navigation.NavigateTo(Navigation.Uri, forceLoad: false);
        }
        catch (Exception ex)
        {
            _layoutStatus = ex.Message;
        }
        finally
        {
            _advancing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AdvanceDaysAsync(int days)
    {
        if (_advancing)
            return;

        try
        {
            _advancing = true;
            _layoutStatus = null;

            var result = await TimeAdvanceService.AdvanceDaysAsync(days);
            await LoadGameStateAsync();
            await InboxStatusService.RefreshAsync();
            await HighlightNotificationService.RefreshAsync();

            _layoutStatus = result.Message;
            Navigation.NavigateTo(Navigation.Uri, forceLoad: false);
        }
        catch (Exception ex)
        {
            _layoutStatus = ex.Message;
        }
        finally
        {
            _advancing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AdvanceToNextMilestoneAsync()
    {
        if (_advancing)
            return;

        try
        {
            _advancing = true;
            _layoutStatus = null;

            var result = await TimeAdvanceService.AdvanceToNextMilestoneAsync();
            await LoadGameStateAsync();
            await InboxStatusService.RefreshAsync();
            await HighlightNotificationService.RefreshAsync();

            _layoutStatus = result.Message;
            Navigation.NavigateTo(Navigation.Uri, forceLoad: false);
        }
        catch (Exception ex)
        {
            _layoutStatus = ex.Message;
        }
        finally
        {
            _advancing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenInbox()
    {
        Navigation.NavigateTo("/inbox");
    }

    private void HandleInboxStatusChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleHighlightChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task DismissHighlightAsync(int messageId)
    {
        await HighlightNotificationService.DismissAsync(messageId);
        await InboxStatusService.RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissAllHighlightsAsync()
    {
        foreach (var item in HighlightNotificationService.Items.ToList())
            await HighlightNotificationService.DismissAsync(item.Id);

        await InboxStatusService.RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    private static string BuildTickerText(MMAAgent.Web.Models.HighlightNotificationVm item)
        => $"{TrimTickerPart(item.Subject)} · {TrimTickerPart(item.Body)}";

    private static string TrimTickerPart(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Trim();
        return normalized.Length <= 140
            ? normalized
            : normalized[..137] + "...";
    }

    private static string FormatHighlightType(string messageType)
        => messageType switch
        {
            "CampUpdate" => "Camp",
            "FightWeekNotice" => "Fight Week",
            "WeighInAlert" => "Weigh-In",
            "FightAftermath" => "Aftermath",
            "FightOfferShortNotice" => "Short Notice",
            _ => "Update"
        };

    private static string FormatAttentionCount(int count)
        => count > 99 ? "99+" : count.ToString();

    public void Dispose()
    {
        InboxStatusService.Changed -= HandleInboxStatusChanged;
        HighlightNotificationService.Changed -= HandleHighlightChanged;
    }
}
