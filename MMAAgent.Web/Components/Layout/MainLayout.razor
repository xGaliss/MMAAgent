@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-glow"></div>

        <div class="brand-block">
            <div class="brand-logo-wrap">
                <div class="brand-logo">M</div>
            </div>

            <div class="brand-copy">
                <div class="brand-title">MMA Agent</div>
                <div class="brand-subtitle">Elite Fight Management</div>
            </div>
        </div>

        <div class="sidebar-section-title">Navigation</div>

        <nav class="sidebar-nav">
            <NavLink href="/dashboard" class="nav-item"><span class="nav-icon">🏠</span><span>Dashboard</span></NavLink>
            <NavLink href="/myfighters" class="nav-item"><span class="nav-icon">🧑‍🤝‍🧑</span><span>My Fighters</span></NavLink>
            <NavLink href="/roster" class="nav-item"><span class="nav-icon">🥊</span><span>Roster</span></NavLink>
            <NavLink href="/promotions" class="nav-item"><span class="nav-icon">🏆</span><span>Promotions</span></NavLink>
            <NavLink href="/events" class="nav-item"><span class="nav-icon">📅</span><span>Events</span></NavLink>
            <NavLink href="/inbox" class="nav-item"><span class="nav-icon">📨</span><span>Inbox</span></NavLink>
            <NavLink href="/agent" class="nav-item"><span class="nav-icon">🕴️</span><span>Agent</span></NavLink>
            <NavLink href="/" class="nav-item"><span class="nav-icon">🎮</span><span>Main Menu</span></NavLink>
        </nav>

        <div class="sidebar-section-title">Career</div>
        <div class="career-card">
            <div class="career-badge">World Save #001</div>
            <div class="career-title">Manager Legacy</div>
            <div class="career-text">Build champions, dominate promotions and shape the future of MMA.</div>
        </div>
    </aside>

    <div class="main-area">
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-kicker">CAREER MODE</div>
                <div class="topbar-title-row">
                    <h1 class="topbar-title">MMA Agent</h1>
                    <span class="live-pill">LIVE UNIVERSE</span>
                </div>
                <div class="topbar-subtitle">Elite fight business simulation</div>
            </div>
        </header>

        <main class="page-content">
            @Body
        </main>
    </div>
</div>
