@inherits LayoutComponentBase
@using MMAAgent.Application.Abstractions
@using MMAAgent.Domain.Common

@inject IGameStateRepository GameStateRepository
@inject IWeeklyWorldUpdateService WeeklyWorldUpdateService
@inject NavigationManager Navigation

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-glow"></div>

        <div class="brand-block">
            <div class="brand-logo-wrap">
                <div class="brand-logo">M</div>
            </div>

            <div class="brand-copy">
                <div class="brand-title">MMA Agent</div>
                <div class="brand-subtitle">Elite Fight Management</div>
            </div>
        </div>

        <div class="sidebar-section-title">Navigation</div>

        <nav class="sidebar-nav">
            <NavLink href="/dashboard" class="nav-item"><span class="nav-icon">🏠</span><span>Dashboard</span></NavLink>
            <NavLink href="/myfighters" class="nav-item"><span class="nav-icon">🧑‍🤝‍🧑</span><span>My Fighters</span></NavLink>
            <NavLink href="/roster" class="nav-item"><span class="nav-icon">🥊</span><span>Roster</span></NavLink>
            <NavLink href="/promotions" class="nav-item"><span class="nav-icon">🏆</span><span>Promotions</span></NavLink>
            <NavLink href="/events" class="nav-item"><span class="nav-icon">📅</span><span>Events</span></NavLink>
            <NavLink href="/inbox" class="nav-item"><span class="nav-icon">📨</span><span>Inbox</span></NavLink>
            <NavLink href="/agent" class="nav-item"><span class="nav-icon">🕴️</span><span>Agent</span></NavLink>
            <NavLink href="/" class="nav-item"><span class="nav-icon">🎮</span><span>Main Menu</span></NavLink>
        </nav>

        
    </aside>

    <div class="main-area">
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-kicker">CAREER MODE</div>

                <div class="topbar-title-row">
                    <h1 class="topbar-title">MMA Agent</h1>
                    <span class="live-pill">LIVE UNIVERSE</span>
                </div>

                <div class="topbar-subtitle">Elite fight business simulation</div>
            </div>

            <div class="topbar-right">
                <div class="date-card topbar-date-card">
                    <div class="date-card-label">Current Week</div>
                    <div class="date-card-value">
                        @(_gameState is null ? "-" : $"Week {_gameState.CurrentWeek} · {_gameState.CurrentDate}")
                    </div>
                </div>

                <button type="button"
                        class="btn-primary"
                        @onclick="AdvanceWeekAsync"
                        disabled="@(_advancing || _loadingState)">
                    @(_advancing ? "Advancing..." : "Advance Week")
                </button>

                <button type="button"
                        class="btn-secondary"
                        @onclick="OpenInbox">
                    Open Inbox
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_layoutStatus))
        {
            <div class="layout-status muted-text">@_layoutStatus</div>
        }

        <main class="page-content">
            @Body
        </main>
    </div>
</div>

@code {
    private GameState? _gameState;
    private bool _loadingState = true;
    private bool _advancing;
    private string? _layoutStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadGameStateAsync();
    }

    private async Task LoadGameStateAsync()
    {
        try
        {
            _loadingState = true;
            _gameState = await GameStateRepository.GetAsync();
        }
        finally
        {
            _loadingState = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AdvanceWeekAsync()
    {
        if (_advancing)
            return;

        try
        {
            _advancing = true;
            _layoutStatus = null;

            var summary = await WeeklyWorldUpdateService.AdvanceWeekAsync();
            await LoadGameStateAsync();

            _layoutStatus = $"Week advanced. New fight offers: {summary.NewFightOffers}. New messages: {summary.NewInboxMessages}.";

            Navigation.NavigateTo(Navigation.Uri, forceLoad: false);
        }
        catch (Exception ex)
        {
            _layoutStatus = ex.Message;
        }
        finally
        {
            _advancing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenInbox()
    {
        Navigation.NavigateTo("/inbox");
    }
}